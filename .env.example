# ============================================================
# ARENDA PLATFORM — Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- DATABASE ---
DATABASE_URL="postgresql://arenda:secret@localhost:5432/arenda_db"

# --- REDIS ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
API_PORT=3001
NODE_ENV=development
API_CORS_ORIGIN="http://localhost:3000"

# --- WEB ---
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- STORAGE ---
STORAGE_PROVIDER="S3"   # S3 | AZURE_BLOB | LOCAL
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# Azure (if STORAGE_PROVIDER=AZURE_BLOB)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER=""

# Local (dev only)
LOCAL_STORAGE_PATH="./uploads"

# --- EMAIL (optional Phase 2) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@arenda.ro"

# --- SUPER ADMIN SEED ---
SUPER_ADMIN_EMAIL="admin@arenda.ro"
SUPER_ADMIN_PASSWORD="CHANGE_ME"
