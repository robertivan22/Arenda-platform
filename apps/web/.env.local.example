# ============================================================
# SUPABASE — Required environment variables
# ============================================================
# Get these from: https://supabase.com/dashboard → your project → Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose in the browser (anon key only)
# Never add the SERVICE_ROLE key here — it would be leaked to the browser.
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# Cloudflare Pages: add these same two variables in:
# CF Dashboard → Pages → your project → Settings → Environment variables
# ============================================================
